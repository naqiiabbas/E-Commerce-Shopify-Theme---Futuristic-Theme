{%- comment -%} Gift card — themed minimal. {%- endcomment -%}
<section class="mx-auto flex max-w-md flex-col items-center px-6 pb-16 pt-36 text-center lg:px-8">
  <p class="text-xs font-bold uppercase tracking-[0.25em] text-[var(--color-muted)]">{{ shop.name }} Gift Card</p>
  <h1 class="mt-4 font-display text-5xl tracking-[-0.04em] text-[var(--color-ink)]">{{ gift_card.balance | money }}</h1>
  <div class="mt-8 w-full rounded-[28px] border border-[var(--color-border-soft)] bg-[var(--color-surface-soft)] p-8 shadow-[0_20px_60px_var(--color-card-shadow)]">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">Your gift card code</p>
    <p class="mt-4 select-all rounded-full border border-[var(--color-border-strong)] bg-[var(--color-paper)] px-4 py-3 text-lg tracking-[0.2em] text-[var(--color-ink)]">{{ gift_card.code | format_code }}</p>
  </div>
  <a href="{{ routes.all_products_collection_url }}" class="mt-8 rounded-full bg-[var(--color-ink)] px-6 py-3 text-sm font-semibold text-[var(--color-paper)] transition hover:bg-[var(--color-ink-soft)]">Start shopping</a>
</section>
