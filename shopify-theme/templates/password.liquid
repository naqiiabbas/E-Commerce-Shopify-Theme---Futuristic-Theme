<section class="mx-auto flex max-w-md flex-col items-center px-6 py-32 text-center lg:px-8">
  <p class="font-display text-5xl tracking-[-0.04em] text-[var(--color-ink)]">{{ shop.name }}</p>
  <p class="mt-4 text-base text-[var(--color-muted)]">Opening soon.</p>
  {%- form 'storefront_password', class: 'mt-8 flex w-full max-w-sm gap-3' -%}
    <input type="password" name="password" placeholder="Enter store password" class="min-h-12 flex-1 rounded-full border border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] px-4 text-sm text-[var(--color-ink)] outline-none">
    <button type="submit" class="rounded-full bg-[var(--color-ink)] px-6 py-3 text-sm font-semibold text-[var(--color-paper)]">Enter</button>
  {%- endform -%}
</section>
