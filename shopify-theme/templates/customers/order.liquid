{%- comment -%} Single order view — themed. {%- endcomment -%}
<section class="mx-auto max-w-4xl px-6 pb-16 pt-36 lg:px-8">
  <h1 class="font-display text-4xl tracking-[-0.03em] text-[var(--color-ink)]">Order {{ order.name }}</h1>
  <p class="mt-2 text-sm text-[var(--color-muted)]">Placed {{ order.created_at | date: '%B %-d, %Y' }} · {{ order.financial_status_label }} · {{ order.fulfillment_status_label }}</p>

  <div class="mt-10 overflow-hidden rounded-[28px] border border-[var(--color-border-soft)] bg-[var(--color-surface-soft)]">
    <table class="w-full text-left text-sm">
      <thead class="bg-[var(--color-surface-muted)] text-[var(--color-muted)]">
        <tr>
          <th class="px-6 py-4 font-medium">Product</th>
          <th class="px-6 py-4 font-medium">Qty</th>
          <th class="px-6 py-4 font-medium">Total</th>
        </tr>
      </thead>
      <tbody>
        {%- for line in order.line_items -%}
          <tr class="border-t border-[var(--color-border-soft)] text-[var(--color-ink)]">
            <td class="px-6 py-4">{{ line.title }}</td>
            <td class="px-6 py-4">{{ line.quantity }}</td>
            <td class="px-6 py-4">{{ line.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>

  <div class="mt-8 flex flex-col items-end gap-2 text-sm text-[var(--color-ink)]">
    <div class="flex gap-8"><span class="text-[var(--color-muted)]">Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
    <div class="flex gap-8"><span class="text-[var(--color-muted)]">Shipping</span><span>{{ order.shipping_price | money }}</span></div>
    <div class="flex gap-8 text-base font-semibold"><span>Total</span><span>{{ order.total_net_amount | money }}</span></div>
  </div>

  <a href="{{ routes.account_url }}" class="mt-10 inline-flex rounded-full border border-[var(--color-border-strong)] px-5 py-2.5 text-sm font-semibold text-[var(--color-ink)] transition hover:bg-[var(--color-overlay-soft)]">Back to account</a>
</section>
