{%- comment -%} Reset password — themed card. {%- endcomment -%}
<div class="flex min-h-screen flex-col items-center justify-center px-4 pb-12 pt-36">
  <div class="w-full max-w-md rounded-[32px] border border-[var(--color-border-soft)] bg-[var(--color-surface)] p-6 shadow-2xl backdrop-blur-xl">
    <div class="text-center">
      <h1 class="font-display text-4xl text-[var(--color-ink)]">Reset password</h1>
      <p class="mt-3 text-sm text-[var(--color-muted)]">Enter a new password for your account</p>
    </div>
    {%- form 'reset_customer_password', class: 'mt-8 space-y-5' -%}
      {%- if form.errors -%}
        <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-500">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div>
        <label class="mb-2 block text-sm font-medium text-[var(--color-ink)]">New password</label>
        <input type="password" name="customer[password]" required class="w-full rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] px-4 py-3 text-sm text-[var(--color-ink)] focus:border-[var(--color-brand-primary)] focus:outline-none">
      </div>
      <div>
        <label class="mb-2 block text-sm font-medium text-[var(--color-ink)]">Confirm password</label>
        <input type="password" name="customer[password_confirmation]" required class="w-full rounded-xl border border-[var(--color-border-strong)] bg-[var(--color-surface-soft)] px-4 py-3 text-sm text-[var(--color-ink)] focus:border-[var(--color-brand-primary)] focus:outline-none">
      </div>
      <button type="submit" class="mt-4 w-full rounded-xl bg-[var(--color-ink)] px-4 py-3 text-sm font-semibold text-[var(--color-paper)] transition hover:bg-[var(--color-ink-soft)]">Reset password</button>
    {%- endform -%}
  </div>
</div>
