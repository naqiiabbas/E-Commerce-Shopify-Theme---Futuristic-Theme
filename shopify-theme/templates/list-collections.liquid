{%- comment -%} All collections grid. {%- endcomment -%}
<section class="mx-auto max-w-7xl px-6 pb-16 pt-28 lg:px-8 lg:pt-36">
  <h1 class="font-display text-4xl tracking-[-0.03em] text-[var(--color-ink)] sm:text-5xl">Collections</h1>
  <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="group relative overflow-hidden rounded-3xl border border-[var(--color-border-soft)] bg-[var(--color-surface-muted)]">
        {%- if collection.featured_image -%}
          <img src="{{ collection.featured_image | image_url: width: 700 }}" alt="{{ collection.title | escape }}" class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105">
        {%- endif -%}
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-6">
          <p class="font-display text-2xl text-white">{{ collection.title }}</p>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>
