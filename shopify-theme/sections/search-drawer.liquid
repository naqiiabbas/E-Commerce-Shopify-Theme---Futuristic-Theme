{%- comment -%}
  Slide-down search overlay. Mirrors src/components/layout/search-drawer.tsx.
  Submits to Shopify's native predictive/standard search.
{%- endcomment -%}
<div data-search-root class="pointer-events-none fixed inset-0 z-[60]" aria-hidden="true">
  <div data-search-scrim class="absolute inset-0 bg-[var(--color-scrim)] opacity-0 transition-opacity duration-300"></div>

  <div
    data-search-panel
    class="absolute left-0 right-0 top-0 -translate-y-full border-b border-[var(--color-border-soft)] bg-[var(--color-paper)] shadow-2xl transition-transform duration-300 ease-out"
    role="dialog"
    aria-label="Search"
  >
    <div class="mx-auto max-w-3xl px-6 py-10">
      <div class="flex items-center justify-between">
        <p class="font-display text-2xl tracking-[-0.03em] text-[var(--color-ink)]">Search</p>
        <button type="button" data-close-search aria-label="Close search" class="text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]">
          {% render 'icon', name: 'x', size: 22 %}
        </button>
      </div>
      <form action="{{ routes.search_url }}" method="get" role="search" class="mt-6 flex items-center gap-3 border-b border-[var(--color-border-strong)] pb-3">
        <span class="text-[var(--color-muted)]">{% render 'icon', name: 'search', size: 22 %}</span>
        <input
          type="search"
          name="q"
          data-search-input
          placeholder="Search products, articles..."
          autocomplete="off"
          class="w-full bg-transparent text-lg text-[var(--color-ink)] outline-none placeholder:text-[var(--color-muted)]"
        >
      </form>
      <p class="mt-4 text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">Press Enter to search</p>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Search drawer", "settings": [] }
{% endschema %}
