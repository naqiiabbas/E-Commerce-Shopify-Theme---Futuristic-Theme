{%- comment -%} Collection grid. {%- endcomment -%}
<section class="mx-auto max-w-7xl px-6 pb-12 pt-28 lg:px-8 lg:pt-36">
  <header class="mb-10">
    <h1 class="font-display text-4xl tracking-[-0.03em] text-[var(--color-ink)] sm:text-5xl">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">{{ collection.description | strip_html }}</p>
    {%- endif -%}
  </header>

  {%- if collection.products.size > 0 -%}
    {%- paginate collection.products by 12 -%}
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {%- for product in collection.products -%}
          {% render 'product-card', card_product: product %}
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <div class="mt-12 flex justify-center gap-2 text-sm text-[var(--color-muted)]">{{ paginate | default_pagination }}</div>
      {%- endif -%}
    {%- endpaginate -%}
  {%- else -%}
    <p class="text-[var(--color-muted)]">No products in this collection yet.</p>
  {%- endif -%}
</section>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
