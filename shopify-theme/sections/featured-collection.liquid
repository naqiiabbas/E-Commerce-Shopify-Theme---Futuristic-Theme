{%- comment -%} A featured product grid for the homepage. {%- endcomment -%}
<section class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
  <div class="mb-10 text-center">
    <h2 class="font-display text-4xl tracking-[-0.03em] text-[var(--color-ink)] sm:text-5xl">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- assign coll = section.settings.collection -%}
  {%- if coll != blank and coll.products.size > 0 -%}
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {%- for product in coll.products limit: section.settings.limit -%}
        {% render 'product-card', card_product: product %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="text-center text-sm text-[var(--color-muted)]">Pick a collection in the theme editor to feature products here.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The recovery lineup" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Red light panels, sauna, and compression — engineered as one premium system." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 3, "max": 12, "step": 3, "default": 6 }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
