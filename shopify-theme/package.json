{
  "name": "somara-labs-shopify-theme",
  "version": "0.1.0",
  "private": true,
  "description": "Somara Labs Shopify theme (ported 1:1 from the Next.js custom design).",
  "scripts": {
    "css": "tailwindcss -i ./src/theme.css -o ./assets/theme.css",
    "css:watch": "tailwindcss -i ./src/theme.css -o ./assets/theme.css --watch",
    "css:build": "tailwindcss -i ./src/theme.css -o ./assets/theme.css --minify",
    "dev": "shopify theme dev",
    "push": "shopify theme push",
    "pull": "shopify theme pull"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0"
  }
}
