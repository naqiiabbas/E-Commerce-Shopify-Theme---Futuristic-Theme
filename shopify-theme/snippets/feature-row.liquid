{%- comment -%}
  Ported from FeatureCard in src/components/marketing/cards.tsx
  Param: block (a 'feature' block), reverse (bool)
  accent: sage | blue | peach | lavender
{%- endcomment -%}
{%- assign accent = block.settings.accent | default: 'sage' -%}
{%- case accent -%}
  {%- when 'sage' -%}{%- assign accent_grad = 'from-[var(--color-accent-sage)]/25 to-white' -%}
  {%- when 'blue' -%}{%- assign accent_grad = 'from-[var(--color-accent-blue)]/25 to-white' -%}
  {%- when 'peach' -%}{%- assign accent_grad = 'from-[var(--color-accent-peach)]/28 to-white' -%}
  {%- when 'lavender' -%}{%- assign accent_grad = 'from-[var(--color-accent-lavender)]/25 to-white' -%}
{%- endcase -%}

<article class="grid items-center gap-10 rounded-[36px] border border-[var(--color-border-soft)] bg-[var(--color-surface)] p-8 shadow-[0_20px_80px_var(--color-card-shadow)] backdrop-blur-xl lg:grid-cols-2 lg:p-12{% if reverse %} lg:[&>*:first-child]:order-2{% endif %}" {{ block.shopify_attributes }}>
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">{{ block.settings.eyebrow }}</p>
    <h3 class="mt-4 font-display text-4xl leading-[1] tracking-[-0.03em] text-[var(--color-ink)]">{{ block.settings.title }}</h3>
    <p class="mt-5 text-base leading-8 text-[var(--color-muted)]">{{ block.settings.description }}</p>
    <ul class="mt-6 space-y-3">
      {%- assign benefits = block.settings.benefits | newline_to_br | split: '<br />' -%}
      {%- for benefit in benefits -%}
        {%- assign b = benefit | strip -%}
        {%- if b != blank -%}
          <li class="flex items-start gap-3 text-sm leading-7 text-[var(--color-ink)]">
            <span class="mt-1 text-[var(--color-accent-sage)]">{% render 'icon', name: 'check', size: 16 %}</span>
            <span>{{ b }}</span>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
    {%- if block.settings.cta_label != blank -%}
      <a href="{{ block.settings.cta_link | default: '#' }}" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-ink)]">
        {{ block.settings.cta_label }} {% render 'icon', name: 'arrow-up-right', size: 16 %}
      </a>
    {%- endif -%}
  </div>
  {%- comment -%} Video source priority: editor upload > bundled asset > external URL. {%- endcomment -%}
  {%- assign vsrc = '' -%}
  {%- if block.settings.video != blank -%}
    {%- assign m = block.settings.video.sources | where: 'format', 'mp4' -%}
    {%- if m.size > 0 -%}{%- assign vsrc = m.first.url -%}{%- else -%}{%- assign vsrc = block.settings.video.sources.first.url -%}{%- endif -%}
  {%- elsif block.settings.video_key != blank -%}{%- assign vsrc = block.settings.video_key | asset_url -%}
  {%- elsif block.settings.video_url != blank -%}{%- assign vsrc = block.settings.video_url -%}
  {%- endif -%}
  {%- if block.settings.poster_key != blank -%}{%- assign psrc = block.settings.poster_key | asset_url -%}{%- else -%}{%- assign psrc = block.settings.poster_url -%}{%- endif -%}
  {%- if block.settings.image_key != blank -%}{%- assign isrc = block.settings.image_key | asset_url -%}{%- else -%}{%- assign isrc = block.settings.image_url -%}{%- endif -%}
  <div class="relative min-h-[360px] overflow-hidden rounded-[30px] border border-[var(--color-border-strong)] bg-gradient-to-br {{ accent_grad }} p-6">
    <div class="ambient-orb absolute right-0 top-0 h-32 w-32 bg-[var(--color-surface-strong)]"></div>
    {%- if vsrc != blank -%}
      <video src="{{ vsrc }}" autoplay loop muted playsinline {% if psrc != blank %}poster="{{ psrc }}"{% endif %} class="relative h-full w-full rounded-[28px] border border-[var(--color-border-strong)] object-cover shadow-[0_20px_50px_var(--color-card-shadow)] backdrop-blur-xl"></video>
    {%- elsif isrc != blank -%}
      <img src="{{ isrc }}" alt="{{ block.settings.title | escape }}" class="relative h-full w-full rounded-[28px] border border-[var(--color-border-strong)] object-cover shadow-[0_20px_50px_var(--color-card-shadow)] backdrop-blur-xl">
    {%- endif -%}
  </div>
</article>
