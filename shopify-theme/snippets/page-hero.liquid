{%- comment -%}
  Ported from src/components/marketing/page-hero.tsx
  Params: eyebrow, heading, description, primary_label, primary_link
{%- endcomment -%}
<section class="relative overflow-hidden px-6 pb-12 pt-28 lg:px-8 lg:pt-32">
  <div class="ambient-orb absolute left-0 top-10 h-64 w-64 bg-[var(--color-accent-peach)]/20"></div>
  <div class="ambient-orb absolute right-10 top-0 h-72 w-72 bg-[var(--color-accent-blue)]/18"></div>
  <div class="reveal mx-auto max-w-5xl rounded-[36px] border border-[var(--color-border-soft)] bg-[var(--color-surface)] px-8 py-16 shadow-[0_24px_90px_var(--color-card-shadow)] backdrop-blur-2xl sm:px-12">
    {% render 'section-heading', eyebrow: eyebrow, heading: heading, description: description, align: 'center' %}
    <div class="mt-8 flex justify-center">
      <a href="{{ primary_link | default: '/pages/contact' }}" class="inline-flex items-center justify-center rounded-full bg-[var(--color-brand-primary)] px-5 py-3 text-sm font-semibold tracking-[0.02em] text-[var(--color-paper)] shadow-[0_18px_40px_var(--color-brand-glow)] transition-all duration-300 hover:bg-[var(--color-brand-secondary)]">{{ primary_label | default: 'Book a demo' }}</a>
    </div>
  </div>
</section>
